#BlueJ class context
comment0.target=Player
comment0.text=\n\ Stores\ the\ state\ that\ belongs\ to\ the\ player\:\ identity,\ current\ position,\ history,\n\ and\ a\ personal\ item\ list.\n\n\ @author\ Barnabe\ Jouanard\n\ @version\ 2026.04.13\n
comment1.params=pName\ pStartRoom
comment1.target=Player(java.lang.String,\ Room)
comment1.text=\n\ Creates\ a\ player\ with\ a\ name\ and\ a\ starting\ room.\n\n\ @param\ pName\ \ \ \ \ \ the\ player\ name\ (can\ be\ empty\ or\ {@code\ null})\n\ @param\ pStartRoom\ the\ initial\ room\n
comment10.params=pName
comment10.target=void\ removeItem(java.lang.String)
comment10.text=\n\ Removes\ an\ item\ from\ the\ player's\ inventory.\n\n\ @param\ pName\ lookup\ key\ of\ the\ item\ to\ remove\n
comment11.params=
comment11.target=int\ getMoney()
comment11.text=\n\ Returns\ the\ player's\ current\ money\ balance.\n\n\ @return\ the\ amount\ of\ money\ the\ player\ has\n
comment12.params=pNewMoney
comment12.target=void\ setMoney(int)
comment12.text=\n\ Sets\ the\ player's\ money\ balance.\n\n\ @param\ pNewMoney\ the\ new\ amount\ of\ money\n
comment13.params=
comment13.target=java.lang.String\ getItemInventory()
comment13.text=\n\ Returns\ a\ human-readable\ inventory\ summary.\n\n\ @return\ formatted\ item\ list\ including\ total\ value\n
comment2.params=
comment2.target=Room\ getCurrentRoom()
comment2.text=\n\ Returns\ the\ player's\ current\ room.\n\n\ @return\ the\ current\ room\ (may\ be\ {@code\ null}\ if\ not\ initialized)\n
comment3.params=pNextRoom
comment3.target=void\ moveTo(Room)
comment3.text=\n\ Changes\ the\ current\ room,\ saving\ the\ previous\ one\ to\ the\ history\ stack.\n\ <p>\n\ Intended\ to\ be\ called\ by\ the\ engine\ after\ validating\ the\ intended\ direction.\n\ </p>\n\n\ @param\ pNextRoom\ the\ room\ to\ move\ to\ (may\ be\ {@code\ null})\n
comment4.params=
comment4.target=boolean\ canGoBack()
comment4.text=\n\ Indicates\ whether\ the\ player\ can\ go\ back\ to\ a\ previous\ room.\n\n\ @return\ {@code\ true}\ if\ a\ previous\ room\ exists\ in\ the\ history\ stack\n
comment5.params=
comment5.target=void\ goBack()
comment5.text=\n\ Moves\ back\ to\ the\ previous\ room.\n\ <p>\n\ This\ method\ assumes\ {@link\ \#canGoBack()}\ is\ {@code\ true}.\ If\ the\ stack\ is\ empty,\n\ {@link\ Stack\#pop()}\ will\ throw\ an\ exception.\n\ </p>\n
comment6.params=
comment6.target=java.lang.String\ getName()
comment6.text=\n\ Returns\ the\ player\ name.\n\n\ @return\ the\ current\ name\ (may\ be\ {@code\ null})\n
comment7.params=pName
comment7.target=void\ setName(java.lang.String)
comment7.text=\n\ Sets\ the\ player\ name.\n\n\ @param\ pName\ the\ new\ name\ (may\ be\ {@code\ null})\n
comment8.params=pName
comment8.target=Item\ getItem(java.lang.String)
comment8.text=\n\ Retrieves\ an\ item\ from\ the\ player's\ inventory.\n\n\ @param\ pName\ lookup\ key\ used\ when\ the\ item\ was\ added\n\ @return\ the\ matching\ {@link\ Item},\ or\ {@code\ null}\n
comment9.params=pName\ pItem
comment9.target=void\ addItem(java.lang.String,\ Item)
comment9.text=\n\ Adds\ (or\ replaces)\ an\ item\ in\ the\ player's\ inventory.\n\n\ @param\ pName\ lookup\ key\ used\ for\ later\ retrieval\n\ @param\ pItem\ the\ item\ to\ store\n
